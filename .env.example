# ===== 高考志愿方案生成器 · 环境变量 =====
# 复制为 .env 并填入实际值

# DeepSeek API（必填）
# 申请：https://platform.deepseek.com/ → 创建 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 搜索引擎选择（开发期用 ddg 免费抓取，上线切 tavily）
# 可选：ddg（DuckDuckGo，默认）/ bing / tavily
SEARCH_PROVIDER=ddg

# Tavily API（上线后启用，开发期可不填）
# 申请：https://tavily.com/ → 注册即得 1000 次/月免费额度
TAVILY_API_KEY=

# 服务端口
PORT=3000

# Agent 循环上限（防止失控）
AGENT_MAX_ROUNDS=8

# 单次请求搜索次数上限
SEARCH_MAX_CALLS=15
