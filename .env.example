# ===== 高考志愿方案生成器 · 环境变量 =====
# 复制为 .env 并填入实际值

# DeepSeek API（必填）
# 申请：https://platform.deepseek.com/ → 创建 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 搜索引擎选择（开发期用 ddg 免费抓取，上线切 tavily）
# 可选：ddg（DuckDuckGo，默认）/ bing / tavily
SEARCH_PROVIDER=ddg

# Tavily API（上线后启用，开发期可不填）
# 申请：https://tavily.com/ → 注册即得 1000 次/月免费额度
TAVILY_API_KEY=

# 服务端口
PORT=3000

# 本地 SQLite 数据库（服务端文件，不要放到 web/ 静态目录）
DATABASE_PATH=./data/app.db

# 管理员页面/API 口令：用于生成邀请码和查看留言
ADMIN_TOKEN=change-this-admin-token

# Agent 循环上限（防止失控）
AGENT_MAX_ROUNDS=8

# 单次请求搜索次数上限
SEARCH_MAX_CALLS=15

# 单次搜索超时（毫秒）
SEARCH_TIMEOUT_MS=10000

# 结构化数据接口（一分一段/批次线）单次请求超时（毫秒）
GAOKAO_TIMEOUT_MS=8000

# Agent 总时间预算：超过后不再开新一轮，尽量在前端超时前收尾（毫秒）
AGENT_DEADLINE_MS=195000

# 单次 DeepSeek 调用超时上限（毫秒）
DEEPSEEK_TIMEOUT_MS=120000

# 生成报告全局并发上限：超出排队，队满或等待超时快速失败（不消耗邀请码）
GENERATE_MAX_CONCURRENT=8
GENERATE_QUEUE_MAX=10
GENERATE_QUEUE_WAIT_MS=30000
