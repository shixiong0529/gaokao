# Nginx 反向代理配置示例
# 部署：sudo cp nginx.conf.example /etc/nginx/sites-available/gaokao && sudo ln -s /etc/nginx/sites-available/gaokao /etc/nginx/sites-enabled/
# 重载：sudo nginx -t && sudo nginx -s reload

# 开发期（IP:80 反代到 3000，无需域名）
server {
    listen 80;
    server_name _;  # 开发期用 IP，备案后改为你的域名

    client_max_body_size 2m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Agent 调用可能耗时较长（30-60s）
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}

